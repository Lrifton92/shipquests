# --- Server-only secrets (NEVER prefix with NEXT_PUBLIC) ---
# Trusted backend attestor private key that signs EIP-712 claim attestations.
# Must correspond to the `signer` address passed to QuestEscrow's constructor.
SIGNER_PRIVATE_KEY=0x

# --- Public (safe to expose to the client) ---
# Deployed QuestEscrow address on Celo mainnet (placeholder until deploy).
NEXT_PUBLIC_QUEST_ESCROW_ADDRESS=0x0000000000000000000000000000000000000000

# Optional Celo RPC override (defaults to https://forno.celo.org).
CELO_RPC_URL=https://forno.celo.org

# Optional Celo RPC for the MiniApp (client-side reads). Defaults to forno.
NEXT_PUBLIC_CELO_RPC_URL=https://forno.celo.org

# --- Referral (off-chain on Vercel KV) ---
# Vercel KV REST credentials. Injected automatically when you attach a Vercel KV
# store to the project (Storage tab). Leave blank locally: the referral system
# degrades to a safe no-op (it never blocks the claim flow or the app).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Id of the dedicated referral quest (create it onchain like any quest, then put
# its id here). Claiming THIS quest pays a referral bonus instead of checking an
# onchain action: it requires the wallet to have eligibleBonuses > 0. Leave blank
# until the quest exists — the Invite page hides the claim CTA when unset.
NEXT_PUBLIC_REFERRAL_QUEST_ID=
