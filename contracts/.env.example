# Copy to .env and fill in. NEVER commit .env (it is gitignored).

# Deployer account private key. Needs a little CELO on the target chain for gas.
DEPLOYER_PRIVATE_KEY=0x...

# RPC endpoints (defaults exist in hardhat.config.ts; override here if needed)
CELO_RPC_URL=https://forno.celo.org
ALFAJORES_RPC_URL=https://alfajores-forno.celo-testnet.org

# Etherscan v2 / Celoscan API key for contract verification.
ETHERSCAN_API_KEY=
